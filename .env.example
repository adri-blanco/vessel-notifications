# --- Supabase ---
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your-anon-or-service-key

# --- Telegram ---
TELEGRAM_BOT_TOKEN=123456:ABCdef...
TELEGRAM_CHAT_ID=-100123456789

# --- AIS source ---
# Which source to use: udp | tcp | serial | file
AIS_SOURCE=udp

# UDP source (default, rtl-ais or AIS-catcher)
AIS_UDP_HOST=127.0.0.1
AIS_UDP_PORT=10110

# TCP source (e.g. SignalK, AIS-catcher --server)
AIS_TCP_HOST=127.0.0.1
AIS_TCP_PORT=10110

# Serial source (e.g. dAISy HAT)
AIS_SERIAL_PORT=/dev/ttyAMA0
AIS_SERIAL_BAUD=38400

# File source (replay a .nmea file for testing)
AIS_FILE_PATH=tests/sample.nmea
AIS_FILE_LOOP=false

# --- Behaviour ---
# Minimum seconds between accepting the same MMSI (dedup window)
DEDUP_WINDOW_SECONDS=300

# Timezone for daily/weekly stats (IANA name)
TIMEZONE=Europe/Madrid

# Logging level: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO

# --- Photo enrichment ---
# Attach vessel photos to Telegram notifications.
# Sources tried in order: VesselFinder (scrape), Wikidata by IMO, Wikidata by name.
# Results are cached in the DB; failed lookups are retried after RECHECK_DAYS.
AIS_PHOTO_ENRICHMENT=false
AIS_PHOTO_RECHECK_DAYS=30

# --- Geofence ---
# Only send notifications for vessels inside a defined geographic area.
# Define the boundary as semicolon-separated lat,lon pairs (minimum 3 points).
# Points are connected in order; the polygon closes automatically.
# Leave unset (or empty) to accept signals from any position.
#
# How to get coordinates:
#   1. Open Google Maps and right-click on each corner of your area → "What's here?"
#   2. Copy the lat,lon shown at the bottom.
#   3. Paste them below in order, tracing the boundary clockwise or counter-clockwise.
#
# Example — a small bay area:
# GEOFENCE_POLYGON=41.3850,2.1730;41.3900,2.1800;41.3950,2.1750;41.3880,2.1680
GEOFENCE_POLYGON=
