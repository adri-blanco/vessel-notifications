# --- Supabase ---
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your-anon-or-service-key

# --- Telegram ---
TELEGRAM_BOT_TOKEN=123456:ABCdef...
TELEGRAM_CHAT_ID=-100123456789

# --- AIS source ---
# Which source to use: udp | tcp | serial | file
AIS_SOURCE=udp

# UDP source (default, rtl-ais or AIS-catcher)
AIS_UDP_HOST=127.0.0.1
AIS_UDP_PORT=10110

# TCP source (e.g. SignalK, AIS-catcher --server)
AIS_TCP_HOST=127.0.0.1
AIS_TCP_PORT=10110

# Serial source (e.g. dAISy HAT)
AIS_SERIAL_PORT=/dev/ttyAMA0
AIS_SERIAL_BAUD=38400

# File source (replay a .nmea file for testing)
AIS_FILE_PATH=tests/sample.nmea
AIS_FILE_LOOP=false

# --- Behaviour ---
# Minimum seconds between accepting the same MMSI (dedup window)
DEDUP_WINDOW_SECONDS=300

# Timezone for daily/weekly stats (IANA name)
TIMEZONE=Europe/Madrid

# Logging level: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO
